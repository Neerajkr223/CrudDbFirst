@model IEnumerable<DbFirstDemo.Models.Student>

@{
    ViewData["Title"] = "Details of Student";
}
@if (TempData["message"] != null)
{
    <div class="alert alert-info" role="alert">
            Message:@TempData["message"]
    </div>
}
@if (TempData["success"] != null)
{
    <div class="alert alert-info" role="alert">
        Message:@TempData["success"]
    </div>
}
<h1>List of Student</h1>

<p>
    <a class="btn btn-success" asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Roll)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StuName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StuGender)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StuDob)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StuPhone)
             </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>

            <td>
                @Html.DisplayFor(modelItem => item.Roll)
            </td>

            <td>
                @Html.DisplayFor(modelItem => item.StuName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StuGender)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StuDob)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StuPhone)
            </td>
            <td>
                <a class="btn btn-primary" asp-action="Edit" asp-route-id="@item.Roll">Edit</a> 
                    <a class="btn btn-warning" asp-action="Details" asp-route-id="@item.Roll">Details</a> 
                    <a class="btn btn-danger" asp-action="Delete" asp-route-id="@item.Roll">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
